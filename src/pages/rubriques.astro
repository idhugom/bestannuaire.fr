---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { SITE, RUBRIQUES, rubriqueUrl } from '../lib/site';

const all = await getCollection('articles');
const counts = new Map<string, number>();
for (const a of all) counts.set(a.data.rubrique, (counts.get(a.data.rubrique) ?? 0) + 1);
---
<Base
  title="Toutes les rubriques"
  description={`Les ${RUBRIQUES.length} univers thématiques de ${SITE.name} : maison, juridique, tech, santé, finance, mode et bien plus.`}
  canonicalPath="/rubriques"
>
  <PageHero
    eyebrow="Explorer"
    title="Toutes les rubriques"
    description={`${RUBRIQUES.length} univers pour naviguer dans nos dossiers, du plus concret au plus pointu.`}
  />
  <section class="wrap wrap--wide" style="padding-top: 2.4rem;">
    <div class="rubindex">
      {RUBRIQUES.map((r, i) => (
        <a href={rubriqueUrl(r.slug)} class="rubtile" data-reveal
           style={`--rub:${r.hue}; --reveal-delay:${Math.min(i * 50, 500)}ms`}>
          <span class="rubtile__icon">{r.icon}</span>
          <span class="rubtile__body">
            <span class="rubtile__label">{r.label}</span>
            <span class="rubtile__desc">{r.desc}</span>
          </span>
          <span class="rubtile__foot">
            <span class="rubtile__count">{counts.get(r.slug) ?? 0} dossier{(counts.get(r.slug) ?? 0) > 1 ? 's' : ''}</span>
            <span class="rubtile__go">Explorer →</span>
          </span>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .rubindex { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1rem; }
  .rubtile {
    display: flex; flex-direction: column; gap: 1rem; padding: 1.6rem;
    border: 1.5px solid var(--line-strong); border-radius: var(--radius); background: var(--card);
    position: relative; overflow: hidden; min-height: 210px;
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease);
  }
  .rubtile::after { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 5px; background: var(--rub); }
  .rubtile:hover { transform: translate(-5px,-5px); box-shadow: var(--hard-shadow); }
  .rubtile__icon { font-family: var(--font-display); font-size: 2.2rem; color: var(--rub); line-height: 1; }
  .rubtile__body { display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
  .rubtile__label { font-family: var(--font-display); font-size: var(--step-2); line-height: 1.02; }
  .rubtile__desc { font-family: var(--font-serif); font-size: 0.98rem; color: var(--ink-2); line-height: 1.45; }
  .rubtile__foot { display: flex; align-items: center; justify-content: space-between; padding-top: 0.8rem; border-top: 1.5px solid var(--line); font-family: var(--font-sans); font-size: 0.8rem; }
  .rubtile__count { color: var(--ink-3); letter-spacing: 0.05em; text-transform: uppercase; }
  .rubtile__go { color: var(--rub); font-weight: 600; opacity: 0; transform: translateX(-8px); transition: opacity 0.3s, transform 0.3s; }
  .rubtile:hover .rubtile__go { opacity: 1; transform: none; }
</style>
