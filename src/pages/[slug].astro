---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { enrichBody } from '../lib/prose';
import { SITE, formatDate, isoDate, rubriqueBySlug, articleUrl, rubriqueUrl } from '../lib/site';
import '../styles/prose.css';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const rub = rubriqueBySlug(d.rubrique);
const { html, toc } = enrichBody(d.bodyHtml);

const all = await getCollection('articles');
const related = all
  .filter((a) => a.data.slug !== d.slug && a.data.rubrique === d.rubrique)
  .sort((a, b) => +b.data.date - +a.data.date)
  .slice(0, 3);
const relatedFallback = related.length < 3
  ? all.filter((a) => a.data.slug !== d.slug && !related.includes(a))
       .sort((a, b) => +b.data.date - +a.data.date)
       .slice(0, 3 - related.length)
  : [];
const relatedAll = [...related, ...relatedFallback];

const canonical = articleUrl(d.slug);
const ogImg = d.heroImage || '/img/og-default.png';

const jsonLd: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: d.title,
    description: d.metaDescription,
    image: d.heroImage ? new URL(d.heroImage, SITE.url).href : undefined,
    datePublished: isoDate(d.date),
    dateModified: isoDate(d.updated ?? d.date),
    inLanguage: 'fr-FR',
    articleSection: rub.label,
    keywords: d.tags.join(', '),
    author: { '@type': 'Organization', name: SITE.author, url: SITE.url },
    publisher: {
      '@type': 'Organization', name: SITE.name,
      logo: { '@type': 'ImageObject', url: `${SITE.url}/img/logo.png` },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(canonical, SITE.url).href },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: rub.label, item: new URL(rubriqueUrl(rub.slug), SITE.url).href },
      { '@type': 'ListItem', position: 3, name: d.title },
    ],
  },
];
if (d.faq.length) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: d.faq.map((f) => ({
      '@type': 'Question', name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}

const shareUrl = encodeURIComponent(new URL(canonical, SITE.url).href);
const shareTitle = encodeURIComponent(d.title);
---
<Base
  title={d.title}
  description={d.metaDescription}
  image={ogImg}
  canonicalPath={canonical}
  type="article"
  publishedTime={isoDate(d.date)}
  modifiedTime={isoDate(d.updated ?? d.date)}
  section={rub.label}
  jsonLd={jsonLd}
  bodyClass="is-article"
>
  <div class="progress"><span class="progress__bar" data-progress></span></div>

  <article data-pagefind-body data-pagefind-meta={`rubrique:${rub.label}`}>
    <!-- HERO -->
    <header class="ahero">
      <div class="wrap wrap--narrow ahero__head">
        <nav class="crumbs" aria-label="Fil d'ariane">
          <a href="/">Accueil</a><span>/</span>
          <a href={rubriqueUrl(rub.slug)}>{rub.short}</a><span>/</span>
          <span class="crumbs__cur">Dossier</span>
        </nav>
        <a href={rubriqueUrl(rub.slug)} class="tag tag--accent ahero__rub" style={`--rub:${rub.hue}`}>{rub.label}</a>
        <h1 class="ahero__title">{d.title}</h1>
        <p class="ahero__chapo">{d.chapo}</p>
        <div class="ahero__meta">
          <span class="ahero__author"><span class="ahero__avatar" aria-hidden="true">✦</span>{SITE.author}</span>
          <span class="ahero__sep">•</span>
          <time datetime={isoDate(d.date)}>{formatDate(d.date)}</time>
          <span class="ahero__sep">•</span>
          <span>{d.readingTime} min de lecture</span>
        </div>
      </div>
      {d.heroImage && (
        <figure class="ahero__figure wrap">
          <img src={d.heroImage} alt={d.heroAlt} width="1280" height="800" fetchpriority="high" data-pagefind-meta="image[src]" />
          {d.heroGenerated && <figcaption>Illustration générée pour {SITE.name}</figcaption>}
        </figure>
      )}
    </header>

    <!-- CORPS -->
    <div class="wrap article-layout">
      <div class="article-main" data-article-body>
        {d.keyTakeaways.length > 0 && (
          <aside class="takeaways" aria-label="L'essentiel">
            <p class="takeaways__h">En bref</p>
            <ul>{d.keyTakeaways.map((k) => (<li>{k}</li>))}</ul>
          </aside>
        )}

        {toc.length > 2 && (
          <details class="toc-mobile">
            <summary>Sommaire ({toc.length})</summary>
            <ol>{toc.map((t) => (<li><a href={`#${t.id}`}>{t.text}</a></li>))}</ol>
          </details>
        )}

        <div class="prose prose--lede" set:html={html} />

        {d.faq.length > 0 && (
          <section class="faq" aria-label="Questions fréquentes">
            <h2 class="faq__h">Questions fréquentes</h2>
            <div class="faq__list">
              {d.faq.map((f) => (
                <details class="faq__item">
                  <summary>{f.q}</summary>
                  <div class="faq__a"><p>{f.a}</p></div>
                </details>
              ))}
            </div>
          </section>
        )}

        {d.tags.length > 0 && (
          <div class="article-tags">
            {d.tags.map((t) => (<span class="tag tag--ghost">#{t}</span>))}
          </div>
        )}

        <div class="share">
          <span class="share__label">Partager</span>
          <a class="share__btn" href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`} target="_blank" rel="noopener" aria-label="Partager sur X">X</a>
          <a class="share__btn" href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener" aria-label="Partager sur Facebook">f</a>
          <a class="share__btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`} target="_blank" rel="noopener" aria-label="Partager sur LinkedIn">in</a>
          <button class="share__btn" data-copy-link aria-label="Copier le lien">⧉</button>
        </div>
      </div>

      <aside class="article-rail">
        {toc.length > 2 && (
          <nav class="toc" data-toc aria-label="Sommaire">
            <p class="toc__h">Sommaire</p>
            <ol>{toc.map((t) => (<li><a href={`#${t.id}`}>{t.text}</a></li>))}</ol>
          </nav>
        )}
        <div class="rail-cta">
          <p class="rail-cta__h">{rub.label}</p>
          <p class="rail-cta__p">Tous nos dossiers de la rubrique.</p>
          <a href={rubriqueUrl(rub.slug)} class="btn btn--accent" style="width:100%; justify-content:center;">Explorer →</a>
        </div>
      </aside>
    </div>
  </article>

  {relatedAll.length > 0 && (
    <section class="wrap wrap--wide related">
      <div class="section-head"><h2>À lire aussi</h2><a href="/articles" class="more">Tous les dossiers</a></div>
      <div class="related__grid">
        {relatedAll.map((a, i) => (<ArticleCard article={a} index={i} />))}
      </div>
    </section>
  )}
</Base>

<style>
  .progress { position: fixed; top: 0; left: 0; right: 0; height: 3px; z-index: 200; background: transparent; }
  .progress__bar { display: block; height: 100%; width: 100%; background: var(--accent); transform: scaleX(0); transform-origin: left; }

  .ahero { padding-top: clamp(1.5rem, 3vw, 2.6rem); }
  .ahero__head { text-align: left; }
  .crumbs { font-family: var(--font-sans); font-size: 0.76rem; letter-spacing: 0.04em; color: var(--ink-3); display: flex; gap: 0.5em; align-items: center; margin-bottom: 1.4rem; text-transform: uppercase; }
  .crumbs a:hover { color: var(--accent-ink); }
  .crumbs__cur { color: var(--ink-2); }
  .ahero__rub { margin-bottom: 1.1rem; background: var(--rub); border-color: var(--rub); color: #fff; }
  .ahero__title { font-size: var(--step-4); line-height: 0.98; margin-bottom: 1rem; }
  .ahero__chapo { font-family: var(--font-serif); font-size: var(--step-1); line-height: 1.4; color: var(--ink-2); max-width: 62ch; }
  .ahero__meta { display: flex; align-items: center; gap: 0.7em; flex-wrap: wrap; margin-top: 1.6rem; font-family: var(--font-sans); font-size: 0.86rem; color: var(--ink-2); }
  .ahero__author { display: inline-flex; align-items: center; gap: 0.5em; font-weight: 600; }
  .ahero__avatar { width: 1.8em; height: 1.8em; display: grid; place-items: center; background: var(--accent); color: #fff; border-radius: 50%; font-size: 0.8em; }
  :root[data-theme="dark"] .ahero__avatar { color: #14110C; }
  .ahero__sep { color: var(--accent); }

  .ahero__figure { margin-top: clamp(1.8rem, 4vw, 3rem); }
  .ahero__figure img { width: 100%; aspect-ratio: 16/10; object-fit: cover; border: 1.5px solid var(--line-strong); border-radius: var(--radius); box-shadow: var(--hard-shadow); }
  .ahero__figure figcaption { font-family: var(--font-sans); font-size: 0.78rem; color: var(--ink-3); margin-top: 0.7rem; padding-left: 0.7rem; border-left: 3px solid var(--accent); }

  .article-layout { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 4vw, 3.5rem); margin-top: clamp(2.4rem, 5vw, 4rem); align-items: start; }
  @media (min-width: 1080px) { .article-layout { grid-template-columns: minmax(0, 1fr) 290px; } }
  .article-main { max-width: 760px; margin-inline: auto; width: 100%; }

  .takeaways { border: 1.5px solid var(--line-strong); border-left: 6px solid var(--accent); border-radius: var(--radius); background: var(--card); padding: 1.3rem 1.5rem; margin-bottom: 2rem; box-shadow: var(--hard-shadow-sm); }
  .takeaways__h { font-family: var(--font-sans); font-weight: 700; font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-ink); margin-bottom: 0.7rem; }
  :root[data-theme="dark"] .takeaways__h { color: var(--accent); }
  .takeaways ul { list-style: none; padding: 0; display: grid; gap: 0.55rem; font-family: var(--font-serif); }
  .takeaways li { padding-left: 1.6em; position: relative; line-height: 1.45; }
  .takeaways li::before { content: "✓"; position: absolute; left: 0; color: var(--accent); font-weight: 700; }

  .toc-mobile { margin-bottom: 2rem; border: 1.5px solid var(--line-strong); border-radius: var(--radius); padding: 0.4rem 1rem; font-family: var(--font-sans); }
  @media (min-width: 1080px) { .toc-mobile { display: none; } }
  .toc-mobile summary { font-weight: 600; padding: 0.6rem 0; cursor: pointer; }
  .toc-mobile ol { padding-left: 1.2rem; margin: 0.5rem 0 1rem; display: grid; gap: 0.4rem; font-size: 0.92rem; }
  .toc-mobile a:hover { color: var(--accent-ink); }

  .article-rail { display: none; }
  @media (min-width: 1080px) { .article-rail { display: block; position: sticky; top: 100px; align-self: start; } }
  .toc { border-top: 2px solid var(--line-strong); padding-top: 1rem; margin-bottom: 2rem; }
  .toc__h { font-family: var(--font-sans); font-weight: 700; font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 0.9rem; }
  .toc ol { list-style: none; padding: 0; display: grid; gap: 0.1rem; counter-reset: toc; }
  .toc li { counter-increment: toc; }
  .toc a { display: block; padding: 0.4rem 0 0.4rem 1.8rem; font-family: var(--font-sans); font-size: 0.85rem; line-height: 1.3; color: var(--ink-2); position: relative; border-left: 2px solid var(--line); transition: color 0.3s, border-color 0.3s; }
  .toc a::before { content: counter(toc, decimal-leading-zero); position: absolute; left: 0.5rem; color: var(--ink-3); font-size: 0.7rem; }
  .toc a:hover { color: var(--accent-ink); }
  .toc a.is-active { color: var(--accent-ink); border-left-color: var(--accent); font-weight: 600; }
  :root[data-theme="dark"] .toc a.is-active, :root[data-theme="dark"] .toc a:hover { color: var(--accent); }

  .rail-cta { border: 1.5px solid var(--line-strong); border-radius: var(--radius); padding: 1.3rem; background: var(--card); }
  .rail-cta__h { font-family: var(--font-display); font-size: 1.3rem; line-height: 1.05; margin-bottom: 0.4rem; }
  .rail-cta__p { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-2); margin-bottom: 1rem; }

  .faq { margin-top: 3.5rem; padding-top: 1rem; }
  .faq__h { font-size: var(--step-2); border-top: 3px solid var(--accent); padding-top: 1.2rem; margin-bottom: 1.4rem; }
  .faq__list { display: grid; gap: 0.7rem; }
  .faq__item { border: 1.5px solid var(--line-strong); border-radius: var(--radius); background: var(--card); overflow: hidden; }
  .faq__item summary { font-family: var(--font-display); font-size: 1.15rem; font-weight: 540; padding: 1.1rem 1.3rem; cursor: pointer; list-style: none; display: flex; justify-content: space-between; gap: 1rem; align-items: center; }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary::after { content: "+"; font-family: var(--font-sans); font-size: 1.5rem; color: var(--accent); transition: transform 0.3s; }
  .faq__item[open] summary::after { transform: rotate(45deg); }
  .faq__a { padding: 0 1.3rem 1.3rem; font-family: var(--font-serif); color: var(--ink-2); line-height: 1.6; }

  .article-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2.5rem; }
  .share { display: flex; align-items: center; gap: 0.6rem; margin-top: 2rem; padding-top: 1.5rem; border-top: 1.5px solid var(--line); }
  .share__label { font-family: var(--font-sans); font-weight: 600; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-3); }
  .share__btn { width: 2.4rem; height: 2.4rem; display: grid; place-items: center; border: 1.5px solid var(--line-strong); border-radius: 50%; font-family: var(--font-sans); font-weight: 700; font-size: 0.9rem; transition: background 0.3s, color 0.3s, transform 0.3s; }
  .share__btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); transform: translateY(-3px); }
  :root[data-theme="dark"] .share__btn:hover { color: #14110C; }

  .related { margin-top: clamp(3.5rem, 7vw, 6rem); }
  .related__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: clamp(1.4rem, 2.5vw, 2.2rem); }
</style>
