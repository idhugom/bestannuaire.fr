---
interface Props {
  current: number;
  total: number;
  basePath: string; // ex: '/articles' ou '/rubrique/maison-jardin'
}
const { current, total, basePath } = Astro.props;
const href = (n: number) => (n <= 1 ? `${basePath}` : `${basePath}/${n}`);

// fenêtre de pages
const win: number[] = [];
const from = Math.max(1, current - 2);
const to = Math.min(total, current + 2);
for (let i = from; i <= to; i++) win.push(i);
---
{total > 1 && (
  <nav class="pager" aria-label="Pagination">
    <a class:list={['pager__nav', { 'is-disabled': current <= 1 }]}
       href={current > 1 ? href(current - 1) : undefined} aria-label="Page précédente">← Précédent</a>
    <ul class="pager__pages">
      {from > 1 && (<><li><a href={href(1)}>1</a></li>{from > 2 && <li class="pager__gap">…</li>}</>)}
      {win.map((n) => (
        <li><a href={href(n)} class:list={['pager__page', { 'is-current': n === current }]}
               aria-current={n === current ? 'page' : undefined}>{n}</a></li>
      ))}
      {to < total && (<>{to < total - 1 && <li class="pager__gap">…</li>}<li><a href={href(total)}>{total}</a></li></>)}
    </ul>
    <a class:list={['pager__nav', { 'is-disabled': current >= total }]}
       href={current < total ? href(current + 1) : undefined} aria-label="Page suivante">Suivant →</a>
  </nav>
)}

<style>
  .pager { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    margin-top: clamp(2.5rem, 5vw, 4rem); padding-top: 1.6rem; border-top: 2px solid var(--line-strong);
    font-family: var(--font-sans); }
  .pager__nav { font-weight: 600; font-size: 0.86rem; padding: 0.6em 1.1em; border: 1.5px solid var(--line-strong); border-radius: 100px; transition: background 0.3s, color 0.3s; }
  .pager__nav:hover { background: var(--ink); color: var(--paper); }
  .pager__nav.is-disabled { opacity: 0.35; pointer-events: none; }
  .pager__pages { list-style: none; display: flex; gap: 0.35rem; padding: 0; align-items: center; }
  .pager__pages a { display: grid; place-items: center; min-width: 2.4rem; height: 2.4rem; padding: 0 0.5rem; border-radius: 100px; font-weight: 600; font-size: 0.9rem; transition: background 0.3s, color 0.3s; }
  .pager__pages a:hover { background: var(--paper-2); }
  .pager__page.is-current { background: var(--accent); color: #fff; }
  :root[data-theme="dark"] .pager__page.is-current { color: #14110C; }
  .pager__gap { color: var(--ink-3); padding: 0 0.2rem; }
  @media (max-width: 560px) { .pager__pages { display: none; } }
</style>
