---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  accent?: string;
  count?: number;
}
const { eyebrow, title, description, accent, count } = Astro.props;
---
<section class="phero" style={accent ? `--rub:${accent}` : ''}>
  <div class="wrap wrap--wide">
    {eyebrow && <p class="eyebrow phero__eyebrow">{eyebrow}</p>}
    <h1 class="phero__title">{title}</h1>
    {description && <p class="phero__desc">{description}</p>}
    {count !== undefined && <p class="phero__count">{count} dossier{count > 1 ? 's' : ''}</p>}
  </div>
  <div class="phero__rule"></div>
</section>

<style>
  .phero { padding-top: clamp(2rem, 5vw, 4rem); padding-bottom: clamp(1.5rem, 3vw, 2.5rem); position: relative; }
  .phero__eyebrow { color: var(--rub, var(--accent-ink)); }
  .phero__title { font-size: var(--step-4); line-height: 0.98; margin-top: 0.5rem; max-width: 20ch; }
  .phero__desc { font-family: var(--font-serif); font-size: var(--step-1); color: var(--ink-2); max-width: 56ch; margin-top: 1.1rem; line-height: 1.4; }
  .phero__count { font-family: var(--font-sans); font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-3); margin-top: 1.2rem; }
  .phero__rule { height: 4px; background: var(--rub, var(--accent)); margin-top: clamp(1.5rem, 3vw, 2.4rem); width: 100%; max-width: var(--maxw); margin-inline: auto; }
  @media (min-width: 1560px) { .phero__rule { max-width: 1560px; } }
</style>
